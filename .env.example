# LLM Intel - Environment Variables Example
# Copy this file to .env and fill in your actual API keys

# Server Configuration
PORT=8787

# Provider Configuration
# Options: mock, openai, groq
DEFAULT_PROVIDER=mock

# OpenAI Configuration (optional - only needed if using OpenAI provider)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Groq Configuration (optional - only needed if using Groq provider)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk-your-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_PRIMARY_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# Retry Configuration
MAX_RETRIES=4
REQUEST_TIMEOUT_MS=10000
BACKOFF_BASE_MS=250
MAX_BACKOFF_MS=8000

# Cost Controls
BUDGET_DAILY_USD=25

# Database (optional - uses in-memory storage by default)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_SSL=false

# Demo Mode (10x faster simulation for testing)
DEMO_MODE=true
